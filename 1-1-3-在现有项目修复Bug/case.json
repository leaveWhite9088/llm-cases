{
  "id": "1-1-3",
  "title": "在现有项目修复 Bug",
  "description": "接手一个已有的前端问题看板，根据缺陷报告定位并修复功能、响应式与健壮性问题，同时控制修改范围。",
  "ability": "编码能力/前端",
  "difficulty": 4,
  "tags": [
    { "path": "编码能力/前端", "weight": 10 },
    { "path": "编码能力/调试", "weight": 9 },
    { "path": "编码能力/测试", "weight": 5 }
  ],
  "scoreRange": [0, 100],
  "workflow": {
    "prompt": "prompts/task.md",
    "rubric": "prompts/rubric.md",
    "checker": "tools/check-deliverable.ps1",
    "inputs": [
      { "source": "starter/index.html", "destination": "index.html" },
      { "source": "starter/styles.css", "destination": "styles.css" },
      { "source": "starter/logic.js", "destination": "logic.js" },
      { "source": "starter/script.js", "destination": "script.js" },
      { "source": "starter/package.json", "destination": "package.json" }
    ],
    "screenshots": {
      "enabled": true,
      "type": "static",
      "entrypoint": "index.html",
      "viewports": [
        { "name": "desktop", "width": 1440, "height": 1000 },
        { "name": "mobile", "width": 390, "height": 844 }
      ]
    }
  }
}
